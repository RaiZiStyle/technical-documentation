{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Build with nob",
            "type": "shell",
            "command": "./nob.elf",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "options": {
                "cwd": "${workspaceFolder}/C/examples"
            },
            "problemMatcher": {
                "base": "$gcc",
                "fileLocation": [
                    "relative",
                    "${workspaceFolder}/C/examples"
                ]
            }
        }
    ]
}